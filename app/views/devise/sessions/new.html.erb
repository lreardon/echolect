<div class="flex justify-center items-center py-[86px]">
  <div
    class="
      flex flex-1 flex-col mx:auto l:flex-row gap-10 l:gap-5 justify-center
      items-center max-w-screen-xl
    "
  >
    <div class="flex-1 flex justify-start">
      <%= render partial: "pages/banner" %>
    </div>
    <div class="flex-1 flex justify-end">
      <div
        class="
          flex flex-col bg-surface p-[18px] m-6 rounded-lg shadow-lg min-w-[400px]
        "
      >
        <%= form_for(resource, as: resource_name, url: session_path(resource_name),) do |f| %>
          <div class="flex flex-col gap-4">
            <div class="field">
              <%= f.email_field :email,
                            autofocus: true,
                            autocomplete: "email",
                            placeholder: "Email",
                            class: "w-full" %>
            </div>
            <div class="field">
              <%= f.password_field :password,
                               autocomplete: "current-password",
                               placeholder: "Password",
                               class: "w-full" %>
            </div>
            <% if devise_mapping.rememberable? %>
              <div class="field flex fled-row gap-2 items-center">
                <%= f.check_box :remember_me %>
                <%= f.label :remember_me %>
              </div>
            <% end %>
            <button class="actions">
              <%= f.submit "Log in" %>
            </button>
            <%= link_to "Forgot your password?", new_password_path(resource_name) %>
          </div>
        <% end %>
        <br>
        <hr>
        <br>
        <%- if devise_mapping.registerable? && controller_name != 'registrations' %>
          <%= link_to "Sign up",
          new_registration_path(resource_name),
          form: {
            class: "flex flex-row w-full",
          },
          class: "special-button w-full" %>
        <% end %>

      </div>
      <br/>

    </div>
  </div>
</div>
