<%# user_1 %>
<%= turbo_stream_from dom_id(current_user) %>
<div class="flex flex-col h-screen justify-end">
		<div class="text-white">
			<h1 class="text-3xl font-bold text-center">Chatroom</h1>
			<p class="text-center">Welcome <%= current_user.username %>!</p>
		</div>
		<div id="chatbox" class="flex flex-col-reverse overflow-y-auto p-3 space-y-reverse justify-end mt-auto">
			<%= render partial: "messages/chatbox", locals: { messages: @messages } %>
	</div>
		<div>
			<%= render partial: "messages/form", locals: { message: @message } %>
		</div>
</div>
