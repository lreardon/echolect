<div>
	<h3>New Chat</h3>
	<div>
		<form 
			data-controller="chats"
			data-reflex="submit->Chats#create"
			data-reflex-root="#user-chats"
			data-reflex-serialize-form
		>
			<div class="flex flex-row gap-5">	
				<input class="flex-1 bg-transparent" data-reflex-chat-name type="text" class="outline focus:outline-white bg-transparent" name="chat[name]" />			
				<button  type="submit"
					id="create-chat"
					class="bg-indigo-900 text-white font-bold py-2 px-4 rounded hover:bg-indigo-800"
				>
					Create Chat
				</button>
			</div>
		</form>
	</div>
</div>