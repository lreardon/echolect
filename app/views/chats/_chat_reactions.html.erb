<%= cable_ready_stream_from "chat-#{chat.id}-reactions" %>

<div class="flex-1 flex flex-col overflow-y-auto text-xl">
	<h2>Reactions</h2>
	<div class="flex-1 flex flex-col-reverse bg-gray-900 overflow-y-auto">
		<div id="chat-<%=chat.id%>-reactions" class="flex flex-wrap">
			<% chat.reactions.each do |reaction| %>
				<%= render partial: 'chats/reaction', locals: { reaction: reaction }%>
			<% end %>
		</div>
	</div>
</div>