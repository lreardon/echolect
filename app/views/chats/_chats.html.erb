<div class="flex flex-col w-full items-center gap-10">
  <h1>Chats</h1>
  <div class="flex flex-col gap-2 w-full">
    <div class="flex flex-row gap-3 items-center justify-between">
      <% if current_user.is_lecturer %>
        <h2>Joined Chats</h2>
      <% end %>
      <%= render partial: "chats/join_chat_form" %>
    </div>
    <%= render partial: "chats/joined_chats" %>
  </div>
  <% if current_user.is_lecturer %>
    <div class="flex flex-col gap-2 w-full">
      <div class="flex flex-row gap-3 items-center justify-between">
        <h2>My Chats</h2>
        <%= render partial: "chats/create_chat_form" %>
      </div>
      <%= render partial: "chats/created_chats" %>
    </div>

  <% end %>
</div>
