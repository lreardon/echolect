<div class="flex flex-col h-full overflow-y-hidden">
	<%= link_to 'Back', root_path %>
	<br/>
	<h1>
		<%= @chat.name %>
	</h1>
	<h3><%= @chat.access_code %></h3>
	<br/>
	<% if current_user == @chat.user %>
		<div class="outline outline-2 outline-green-800 m-1 flex-1 flex flex-col overflow-y-auto">
			<%= render partial: 'chats/speaker_view', locals: { chat: @chat } %>
		</div>
		<br/>
	<% end %>

	<div class="outline outline-2 outline-green-800 m-1 flex-1 flex flex-col overflow-y-auto">
		<%= render partial: 'chats/learner_view' %>
	</div>
</div>